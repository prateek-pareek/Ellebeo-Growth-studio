# ============================================================================
# Elle.Be.O Growth Studio — AI Orchestration Layer
# .gitignore
# ============================================================================

# ---------------------------------------------------------------------------
# Environment & Secrets — NEVER commit these
# ---------------------------------------------------------------------------
.env
.env.local
.env.development
.env.staging
.env.production
.env.*.local

# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js

# ---------------------------------------------------------------------------
# TypeScript Build Output
# ---------------------------------------------------------------------------
dist/
build/
out/
*.js.map
*.d.ts.map

# Compiled JS from TS (only if not intentional)
# Uncomment if you compile to a /dist folder and want to ignore loose JS
# *.js

# ---------------------------------------------------------------------------
# Prisma
# ---------------------------------------------------------------------------
# Keep schema.prisma tracked, but ignore generated client
prisma/generated/
prisma/migrations/dev.db
prisma/migrations/dev.db-journal

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---------------------------------------------------------------------------
# OS / Editor artifacts
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ---------------------------------------------------------------------------
# Testing
# ---------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov
test-results/
playwright-report/

# ---------------------------------------------------------------------------
# Caching & Temp files
# ---------------------------------------------------------------------------
.cache/
.parcel-cache/
.turbo/
tmp/
temp/
*.tmp

# ---------------------------------------------------------------------------
# Package manager lock files (keep only one — this project uses npm)
# ---------------------------------------------------------------------------
yarn.lock
pnpm-lock.yaml
# package-lock.json is intentionally tracked

# ---------------------------------------------------------------------------
# AWS / Cloud credentials
# ---------------------------------------------------------------------------
.aws/
*.pem
*.key
*.cert
*.crt

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
.docker/
docker-compose.override.yml

# ---------------------------------------------------------------------------
# Redis / BullMQ dump files
# ---------------------------------------------------------------------------
dump.rdb
appendonly.aof

# ---------------------------------------------------------------------------
# Miscellaneous
# ---------------------------------------------------------------------------
*.tsbuildinfo
.eslintcache
.stylelintcache
