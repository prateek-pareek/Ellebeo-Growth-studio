{
  "name": "growthstudio-ai-layer",
  "version": "1.0.0",
  "description": "AI Orchestration Layer for Elle.Be.O Growth Studio",
  "main": "dist/index.js",
  "scripts": {
    "build": "npx nest build",
    "dev": "npx nest start --watch",
    "start:dev": "npx nest start --watch",
    "start": "node dist/main.js",
    "worker:content": "ts-node-dev --respawn --transpile-only src/ai/workers/content-generation.worker.ts",
    "worker:image": "ts-node-dev --respawn --transpile-only src/ai/workers/image-processing.worker.ts",
    "worker:video": "ts-node-dev --respawn --transpile-only src/ai/workers/video-assembly.worker.ts",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:load": "artillery run tests/load/generation.yml",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@langchain/anthropic": "^0.1.0",
    "@langchain/core": "^0.1.0",
    "@langchain/openai": "^0.0.28",
    "@nestjs/cache-manager": "^3.1.2",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.19",
    "@opentelemetry/api": "^1.8.0",
    "@opentelemetry/exporter-prometheus": "^0.49.0",
    "@opentelemetry/sdk-node": "^0.49.0",
    "@opentelemetry/sdk-trace-node": "^1.22.0",
    "@prisma/client": "^5.12.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.4.0",
    "cache-manager": "^7.2.8",
    "cache-manager-redis-store": "^3.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cloudinary": "^2.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "firebase-admin": "^12.7.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.3.2",
    "langchain": "^0.1.0",
    "openai": "^4.33.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prom-client": "^15.1.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5",
    "socket.io": "^4.7.4",
    "uuid": "^9.0.1",
    "winston": "^3.13.0",
    "winston-transport": "^4.7.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.5",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.5.0",
    "@typescript-eslint/parser": "^7.5.0",
    "artillery": "^2.0.14",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prisma": "^5.12.0",
    "ts-jest": "^29.1.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
