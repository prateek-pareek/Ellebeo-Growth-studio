generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["platform"]
}

// --- ELLE.BE.O PLATFORM MODELS ---

enum SubscriptionTier {
  free
  standard
  premium

  @@schema("platform")
}

enum TenantStatus {
  active
  restricted
  suspended
  churned

  @@schema("platform")
}

enum ConsentStatus {
  granted
  pending
  declined
  withdrawn

  @@schema("platform")
}

enum PromptCategory {
  general
  medical_aesthetics

  @@schema("platform")
}

enum BusinessGoalType {
  attract_new_clients
  fill_quiet_days
  promote_high_margin_service
  build_brand_authority
  client_retention

  @@schema("platform")
}

enum ContentStatus {
  draft
  pending
  processing
  completed
  approved
  scheduled
  published
  blocked
  flagged
  archived
  failed

  @@schema("platform")
}

enum JobState {
  created
  queued
  processing_image
  processing_vision
  building_prompt
  generating_text
  generating_reel
  completed
  failed
  retrying
  blocked
  dead_letter

  @@schema("platform")
}

enum SocialAccountStatus {
  connected
  disconnected
  token_expired
  error

  @@schema("platform")
}

enum PublishStatus {
  pending
  published
  failed
  cancelled

  @@schema("platform")
}

enum ToneRating {
  sounds_like_me
  close_but_not_quite
  doesnt_sound_like_me

  @@schema("platform")
}

enum BrandAesthetic {
  minimalist_clean
  moody_editorial
  bright_playful
  soft_feminine
  bold_luxury

  @@schema("platform")
}

enum BrandTier {
  luxury
  mainstream
  accessible

  @@schema("platform")
}

model User {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email               String    @unique @db.VarChar(320)
  passwordHash        String    @map("password_hash") @db.VarChar(255)
  role                String    @default("technician") @db.VarChar(50)
  emailVerified       Boolean   @default(false) @map("email_verified")
  emailVerifiedAt     DateTime? @map("email_verified_at") @db.Timestamptz
  lastLoginAt         DateTime? @map("last_login_at") @db.Timestamptz
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until") @db.Timestamptz
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt           DateTime? @map("deleted_at") @db.Timestamptz

  tenant        Tenant?
  refreshTokens RefreshToken[]
  approvedItems ContentItem[]  @relation("ApprovedBy")
  resolvedJobs  FailedJob[]    @relation("ResolvedBy")

  @@index([email])
  @@index([role])
  @@map("users")
  @@schema("platform")
}

model Tenant {
  id                    String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                String           @unique @map("user_id") @db.Uuid
  businessName          String           @map("business_name") @db.VarChar(255)
  displayName           String?          @map("display_name") @db.VarChar(255)
  subscriptionTier      SubscriptionTier @default(free) @map("subscription_tier")
  subscriptionStartedAt DateTime?        @map("subscription_started_at") @db.Timestamptz
  subscriptionExpiresAt DateTime?        @map("subscription_expires_at") @db.Timestamptz
  status                TenantStatus     @default(active)
  hasGrowthStudioAccess Boolean          @default(false) @map("has_growth_studio_access")
  generationRestricted  Boolean          @default(false) @map("generation_restricted")
  generationSuspended   Boolean          @default(false) @map("generation_suspended")
  abuseFlagCount        Int              @default(0) @map("abuse_flag_count")
  lastAbuseFlagAt       DateTime?        @map("last_abuse_flag_at") @db.Timestamptz
  stripeCustomerId         String?          @map("stripe_customer_id") @db.VarChar(255)
  stripeSubscriptionId     String?          @map("stripe_subscription_id") @db.VarChar(255)
  appliedStripeSessionIds  String[]         @default([]) @map("applied_stripe_session_ids")
  trialGenerationsUsed     Int              @default(0) @map("trial_generations_used")
  planGenerationsTotal     Int              @default(0) @map("plan_generations_total")
  planGenerationsUsed      Int              @default(0) @map("plan_generations_used")
  timezone              String           @default("UTC") @db.VarChar(100)
  locale                String           @default("en-AU") @db.VarChar(20)
  avatarUrl             String?          @map("avatar_url") @db.VarChar(2000)
  phone                 String?          @db.VarChar(50)
  onboardingCompleted   Boolean          @default(false) @map("onboarding_completed")
  onboardingStep        Int              @default(1) @map("onboarding_step")
  createdAt             DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt             DateTime?        @map("deleted_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  brandHistory           BrandDNA[]
  brandPillars           BrandPillar[]
  brandGoals             BrandGoal[]
  clients                Client[]
  consentRecords         ConsentRecord[]
  appointments           Appointment[]
  imageAssets            ImageAsset[]
  goldenExamples         GoldenExample[]
  businessGoals          BusinessGoal[]
  generationJobs         GenerationJob[]
  contentItems           ContentItem[]
  socialAccounts         SocialAccount[]
  scheduledPosts         ScheduledPost[]
  campaigns              Campaign[]
  generationAuditLogs    GenerationAuditLog[]
  generationFingerprints GenerationFingerprint[]
  failedJobs             FailedJob[]
  crmIntegrationConfig   CrmIntegrationConfig?
  notifications          Notification[]

  @@index([userId])
  @@index([status])
  @@index([subscriptionTier])
  @@map("tenants")
  @@schema("platform")
}

// Singleton row (id = "default") holding the one purchasable plan's price and
// generation allowance. Admin-editable so the business can tune it against
// real OpenAI cost data without a redeploy.
model PlanSettings {
  id                  String   @id @default("default")
  priceUsd             Float    @default(50) @map("price_usd")
  generationsIncluded  Int      @default(100) @map("generations_included")
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("plan_settings")
  @@schema("platform")
}

model MasterPrompt {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category     PromptCategory
  systemPrompt String         @map("system_prompt") @db.Text
  isActive     Boolean        @default(true) @map("is_active")
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@index([category, isActive])
  @@map("master_prompts")
  @@schema("platform")
}

model BrandDNA {
  id                       String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId                 String        @map("tenant_id") @db.Uuid
  version                  Int           @default(1)
  isCurrent                Boolean       @default(true) @map("is_current")
  businessName             String        @map("business_name") @db.VarChar(255)
  oneLiner                 String?       @map("one_liner") @db.Text
  uniqueSellingProposition String?       @map("unique_selling_proposition") @db.Text
  signatureOutcome         String?       @map("signature_outcome") @db.VarChar(500)
  primaryPersona           String?       @map("primary_persona") @db.VarChar(255)
  secondaryPersona         String?       @map("secondary_persona") @db.VarChar(255)
  clientPainPoints         String[]      @map("client_pain_points")
  primaryTone              String?       @map("primary_tone") @db.VarChar(100)
  secondaryTone            String?       @map("secondary_tone") @db.VarChar(100)
  emojiPolicy              String        @default("minimal") @map("emoji_policy") @db.VarChar(50)
  vocabularyBlacklist      String[]      @map("vocabulary_blacklist")
  vocabularyPreferred      String[]      @map("vocabulary_preferred")
  doNotSay                 String[]      @map("do_not_say")
  formattingStyle          String?       @map("formatting_style") @db.Text
  aestheticDirection       String?       @map("aesthetic_direction") @db.Text
  moodTag                  String?       @map("mood_tag") @db.VarChar(100)
  primaryBrandColor        String?       @map("primary_brand_color") @db.VarChar(50)
  secondaryBrandColor      String?       @map("secondary_brand_color") @db.VarChar(50)
  brandFont                String?       @map("brand_font") @db.VarChar(100)
  locationCity             String?       @map("location_city") @db.VarChar(255)
  brandTier                BrandTier     @default(mainstream) @map("brand_tier")
  captionLengthPreference  String        @default("medium") @map("caption_length_preference") @db.VarChar(50)
  emojiStyle               String        @default("minimal") @map("emoji_style") @db.VarChar(50)
  averageConfidenceScore   Float         @default(0.5) @map("average_confidence_score")
  preferredModelOverride   String?       @map("preferred_model_override") @db.VarChar(100)
  logoUrl                  String?       @map("logo_url") @db.VarChar(2000)
  logoPosition             String        @default("bottom_right") @map("logo_position") @db.VarChar(20)
  lastUpdatedAt            DateTime      @default(now()) @map("last_updated_at") @db.Timestamptz
  autoPopulated            Boolean       @default(false) @map("auto_populated")
  pillars                  BrandPillar[]
  goals                    BrandGoal[]

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, isCurrent], name: "unique_current_brand_dna")
  @@index([tenantId])
  @@map("brand_dna")
  @@schema("platform")
}

model BrandPillar {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  label       String   @db.VarChar(255)
  description String?  @db.Text
  keywords    String[]
  priority    Int      @default(3)
  sortOrder   Int?     @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  brandDNAId String   @map("brand_dna_id") @db.Uuid
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  brandDNA   BrandDNA @relation(fields: [brandDNAId], references: [id])

  @@index([tenantId])
  @@map("brand_pillars")
  @@schema("platform")
}

model BrandGoal {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  label        String   @db.VarChar(255)
  description  String?  @db.Text
  targetMetric String?  @map("target_metric") @db.VarChar(255)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  brandDNAId String   @map("brand_dna_id") @db.Uuid
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  brandDNA   BrandDNA @relation(fields: [brandDNAId], references: [id])

  @@index([tenantId])
  @@map("brand_goals")
  @@schema("platform")
}

model Client {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  firstName   String    @map("first_name") @db.VarChar(255)
  lastName    String    @map("last_name") @db.VarChar(255)
  email       String?   @db.VarChar(320)
  phone       String?   @db.VarChar(50)
  lastVisitAt DateTime? @map("last_visit_at") @db.Timestamptz
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  appointments   Appointment[]
  consentRecords ConsentRecord[]
  generationJobs GenerationJob[]

  @@index([tenantId])
  @@index([email])
  @@map("clients")
  @@schema("platform")
}

model ConsentRecord {
  id                     String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId               String        @map("tenant_id") @db.Uuid
  clientId               String        @map("client_id") @db.Uuid
  appointmentId          String?       @unique @map("appointment_id") @db.Uuid
  status                 ConsentStatus @default(pending)
  allowShowFace          Boolean       @default(false) @map("allow_show_face")
  allowUseName           Boolean       @default(false) @map("allow_use_name")
  allowTagSocial         Boolean       @default(false) @map("allow_tag_social")
  allowPlatformPromotion Boolean       @default(false) @map("allow_platform_promotion")
  allowInternalUse       Boolean       @default(false) @map("allow_internal_use")
  allowMarketingContent  Boolean       @default(false) @map("allow_marketing_content")
  consentMethod          String        @default("manual") @map("consent_method") @db.VarChar(50)
  signatureUrl           String?       @map("signature_url") @db.VarChar(2000)
  withdrawalReason       String?       @map("withdrawal_reason") @db.Text
  grantedAt              DateTime?     @map("granted_at") @db.Timestamptz
  withdrawnAt            DateTime?     @map("withdrawn_at") @db.Timestamptz
  isCurrent              Boolean       @default(true) @map("is_current")
  supersededById         String?       @map("superseded_by_id") @db.Uuid
  createdAt              DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  supersededAt           DateTime?     @map("superseded_at") @db.Timestamptz
  crmBookingId           String?       @map("crm_booking_id") @db.VarChar(255)

  tenant            Tenant          @relation(fields: [tenantId], references: [id])
  client            Client          @relation(fields: [clientId], references: [id])
  appointment       Appointment?    @relation(fields: [appointmentId], references: [id])
  supersededBy      ConsentRecord?  @relation("SupersededBy", fields: [supersededById], references: [id])
  supersededRecords ConsentRecord[] @relation("SupersededBy")

  @@index([tenantId])
  @@index([clientId])
  @@index([status])
  @@map("consent_records")
  @@schema("platform")
}

model Appointment {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String    @map("tenant_id") @db.Uuid
  clientId           String    @map("client_id") @db.Uuid
  consentRecordId    String?   @unique @map("consent_record_id") @db.Uuid
  serviceCategory    String    @map("service_category") @db.VarChar(100)
  serviceName        String    @map("service_name") @db.VarChar(255)
  appointmentDate    DateTime  @map("appointment_date") @db.Timestamptz
  appointmentTime    DateTime? @map("appointment_time") @db.Timestamptz
  durationMinutes    Int?      @map("duration_minutes")
  externalId         String?   @map("external_id") @db.VarChar(255)
  source             String    @default("manual") @db.VarChar(50)
  notes              String?   @db.Text
  serviceDescription String?   @map("service_description") @db.Text
  isCancelled        Boolean   @default(false) @map("is_cancelled")
  cancellationReason String?   @map("cancellation_reason") @db.Text
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt          DateTime? @map("deleted_at") @db.Timestamptz

  crmBookingId String? @map("crm_booking_id") @db.VarChar(255)

  tenant Tenant @relation(fields: [tenantId], references: [id])
  client Client @relation(fields: [clientId], references: [id])

  consentRecord          ConsentRecord?
  generationJobs         GenerationJob[]
  contentItems           ContentItem[]
  imageAssets            ImageAsset[]
  questionnaireResponses AppointmentQuestionnaireResponse[]

  @@index([tenantId, appointmentDate])
  @@index([clientId])
  @@index([crmBookingId])
  @@map("appointments")
  @@schema("platform")
}

model ImageAsset {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String    @map("tenant_id") @db.Uuid
  appointmentId      String?   @map("appointment_id") @db.Uuid
  contentItemId      String?   @map("content_item_id") @db.Uuid
  rawUrl             String?   @map("raw_url") @db.VarChar(2000)
  cloudinaryPublicId String?   @map("cloudinary_public_id") @db.VarChar(500)
  assetType          String    @default("image") @map("asset_type") @db.VarChar(50)
  s3Key              String?   @map("s3_key") @db.VarChar(1000)
  s3Bucket           String?   @map("s3_bucket") @db.VarChar(500)
  s3ObjectHash       String?   @map("s3_object_hash") @db.VarChar(255)
  fileSizeBytes      Int?      @map("file_size_bytes")
  isBeforePhoto      Boolean   @default(false) @map("is_before_photo")
  isAfterPhoto       Boolean   @default(false) @map("is_after_photo")
  crmMediaId         String?   @map("crm_media_id") @db.Uuid
  source             String    @default("manual") @db.VarChar(50)
  uploadValidated    Boolean   @default(false) @map("upload_validated")
  visionAnalysis     Json?     @map("vision_analysis")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  deletedAt          DateTime? @map("deleted_at") @db.Timestamptz

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])
  contentItem ContentItem? @relation(fields: [contentItemId], references: [id])

  @@index([tenantId])
  @@index([contentItemId])
  @@map("image_assets")
  @@schema("platform")
}

model ImageVisionCache {
  hash          String   @id @db.VarChar(64) // SHA256 of image bytes
  model         String   @db.VarChar(100)    // e.g., 'gpt-4o'
  promptVersion String   @map("prompt_version") @db.VarChar(50) // e.g., 'v1.0'
  result        Json
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("image_vision_cache")
  @@schema("platform")
}

model GoldenExample {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  captionText  String    @map("caption_text") @db.Text
  hashtags     String[]
  qualityScore Float     @default(1.0) @map("quality_score")
  isApproved   Boolean   @default(true) @map("is_approved")
  isPending    Boolean   @default(false) @map("is_pending")
  approvedAt   DateTime? @map("approved_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("golden_examples")
  @@schema("platform")
}

model BusinessGoal {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String           @map("tenant_id") @db.Uuid
  goalType     BusinessGoalType @map("goal_type")
  description  String?          @db.Text
  targetValue  Float?           @map("target_value")
  currentValue Float            @default(0) @map("current_value")
  isActive     Boolean          @default(true) @map("is_active")
  startDate    DateTime?        @map("start_date") @db.Date
  endDate      DateTime?        @map("end_date") @db.Date
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, isActive])
  @@map("business_goals")
  @@schema("platform")
}

model GenerationJob {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  appointmentId    String    @map("appointment_id") @db.Uuid
  clientId         String    @map("client_id") @db.Uuid
  state            JobState  @default(created)
  jobPayload       Json      @map("job_payload")
  consentSnapshot  Json      @map("consent_snapshot")
  brandDnaSnapshot Json      @map("brand_dna_snapshot")
  brandDnaVersion  Int       @map("brand_dna_version")
  outputFormats    String[]  @map("output_formats")
  platforms        String[]  @map("platforms")
  includeVoiceover Boolean   @default(false) @map("include_voiceover")
  includeMusic     Boolean   @default(false) @map("include_music")
  errorCode        String?   @map("error_code") @db.VarChar(100)
  errorMessage     String?   @map("error_message") @db.Text
  modelUsed        String?   @map("model_used") @db.VarChar(100)
  tokensInput      Int?      @map("tokens_input")
  tokensOutput     Int?      @map("tokens_output")
  processingMs     Int?      @map("processing_ms")
  estimatedCostUsd Float?    @map("estimated_cost_usd")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  completedAt      DateTime? @map("completed_at") @db.Timestamptz

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  appointment Appointment @relation(fields: [appointmentId], references: [id])
  client      Client      @relation(fields: [clientId], references: [id])

  auditLogs    GenerationAuditLog[]
  failedJobs   FailedJob[]
  contentItems ContentItem[]

  @@index([tenantId, state])
  @@index([appointmentId])
  @@map("generation_jobs")
  @@schema("platform")
}

model ContentItem {
  id                    String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId              String        @map("tenant_id") @db.Uuid
  appointmentId         String        @map("appointment_id") @db.Uuid
  generationJobId       String?       @map("generation_job_id") @db.Uuid
  status                ContentStatus @default(draft)
  captionStatus         ContentStatus @default(draft) @map("caption_status")
  imageStatus           ContentStatus @default(draft) @map("image_status")
  reelStatus            ContentStatus @default(draft) @map("reel_status")
  hookSentence          String?       @map("hook_sentence") @db.Text
  caption               String?       @db.Text
  reelScript            String?       @map("reel_script") @db.Text
  altText               String?       @map("alt_text") @db.Text
  estimatedReadTime     Int?          @map("estimated_read_time")
  confidenceScore       Float?        @map("confidence_score")
  platformVariants      Json?         @map("platform_variants")
  generationOptions     Json[]        @default([]) @map("generation_options")
  selectedModel         String?       @map("selected_model") @db.VarChar(100)
  hashtags              String[]
  callToAction          String?       @map("call_to_action") @db.Text
  voiceoverUrl          String?       @map("voiceover_url") @db.VarChar(2000)
  musicUrl              String?       @map("music_url") @db.VarChar(2000)
  finalVideoUrl         String?       @map("final_video_url") @db.VarChar(2000)
  reelThumbnailUrl      String?       @map("reel_thumbnail_url") @db.VarChar(2000)
  processedImageUrlFeed String?       @map("processed_image_url_feed") @db.VarChar(2000)
  exportPackUrl         String?       @map("export_pack_url") @db.VarChar(2000)
  exportGeneratedAt     DateTime?     @map("export_generated_at") @db.Timestamptz
  technicianToneRating  String?       @map("technician_tone_rating") @db.VarChar(50)
  ratedAt               DateTime?     @map("rated_at") @db.Timestamptz
  isAdminFlagged        Boolean       @default(false) @map("is_admin_flagged")
  flaggedReason         String?       @map("flagged_reason") @db.Text
  blockedReason         String?       @map("blocked_reason") @db.Text
  toneRating            ToneRating?   @map("tone_rating")
  approvedAt            DateTime?     @map("approved_at") @db.Timestamptz
  approvedById          String?       @map("approved_by") @db.Uuid
  createdAt             DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  completedAt           DateTime?     @map("completed_at") @db.Timestamptz
  deletedAt             DateTime?     @map("deleted_at") @db.Timestamptz

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  appointment   Appointment    @relation(fields: [appointmentId], references: [id])
  generationJob GenerationJob? @relation(fields: [generationJobId], references: [id])
  approvedBy    User?          @relation("ApprovedBy", fields: [approvedById], references: [id])

  imageAssets            ImageAsset[]
  scheduledPosts         ScheduledPost[]
  generationFingerprints GenerationFingerprint[]

  @@index([tenantId, status])
  @@index([appointmentId])
  @@map("content_items")
  @@schema("platform")
}

model SocialAccount {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String              @map("tenant_id") @db.Uuid
  platform          String              @db.VarChar(100)
  platformAccountId String?             @map("platform_account_id") @db.VarChar(255)
  accountName       String?             @map("account_name") @db.VarChar(500)
  accountHandle     String?             @map("account_handle") @db.VarChar(500)
  profilePictureUrl String?             @map("profile_picture_url") @db.VarChar(2000)
  status            SocialAccountStatus @default(connected)
  accessToken       String?             @map("access_token") @db.Text
  refreshToken      String?             @map("refresh_token") @db.Text
  tokenExpiresAt    DateTime?           @map("token_expires_at") @db.Timestamptz
  tokenRefreshedAt  DateTime?           @map("token_refreshed_at") @db.Timestamptz
  scopesGranted     String[]            @map("scopes_granted")
  lastPublishAt     DateTime?           @map("last_publish_at") @db.Timestamptz
  lastError         String?             @map("last_error") @db.Text
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  scheduledPosts ScheduledPost[]

  @@unique([tenantId, platform], name: "unique_platform_per_tenant")
  @@index([tenantId])
  @@index([tokenExpiresAt])
  @@map("social_accounts")
  @@schema("platform")
}

model ScheduledPost {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String        @map("tenant_id") @db.Uuid
  contentItemId    String        @map("content_item_id") @db.Uuid
  socialAccountId  String        @map("social_account_id") @db.Uuid
  campaignId       String?       @map("campaign_id") @db.Uuid
  platform         String
  postFormat       String        @map("post_format")
  captionOverride  String?       @map("caption_override") @db.Text
  hashtagsOverride String[]      @map("hashtags_override")
  scheduledFor     DateTime      @map("scheduled_for") @db.Timestamptz
  publishStatus    PublishStatus @default(pending) @map("publish_status")
  publishedAt      DateTime?     @map("published_at") @db.Timestamptz
  platformPostId   String?       @map("platform_post_id") @db.VarChar(500)
  platformPostUrl  String?       @map("platform_post_url") @db.VarChar(2000)
  failedAt         DateTime?     @map("failed_at") @db.Timestamptz
  failureReason    String?       @map("failure_reason") @db.Text
  retryCount       Int           @default(0) @map("retry_count")
  lastRetryAt      DateTime?     @map("last_retry_at") @db.Timestamptz
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt        DateTime?     @map("deleted_at") @db.Timestamptz

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  contentItem   ContentItem   @relation(fields: [contentItemId], references: [id])
  socialAccount SocialAccount @relation(fields: [socialAccountId], references: [id])
  campaign      Campaign?     @relation(fields: [campaignId], references: [id])

  @@index([tenantId])
  @@index([tenantId, scheduledFor])
  @@index([contentItemId])
  @@index([campaignId])
  @@map("scheduled_posts")
  @@schema("platform")
}

model Campaign {
  id                  String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String            @map("tenant_id") @db.Uuid
  name                String            @db.VarChar(500)
  description         String?           @db.Text
  goalType            BusinessGoalType? @map("goal_type")
  startDate           DateTime?         @map("start_date") @db.Date
  endDate             DateTime?         @map("end_date") @db.Date
  totalPostsPlanned   Int               @default(0) @map("total_posts_planned")
  totalPostsApproved  Int               @default(0) @map("total_posts_approved")
  totalPostsPublished Int               @default(0) @map("total_posts_published")
  isActive            Boolean           @default(true) @map("is_active")
  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt           DateTime?         @map("deleted_at") @db.Timestamptz

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  scheduledPosts ScheduledPost[]

  @@index([tenantId])
  @@map("campaigns")
  @@schema("platform")
}

model GenerationAuditLog {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId               String   @map("tenant_id") @db.Uuid
  jobId                  String?  @map("job_id") @db.Uuid
  timestamp              DateTime @default(now()) @db.Timestamptz
  inputInstruction       String?  @map("input_instruction") @db.Text
  sanitisationPassed     Boolean  @map("sanitisation_passed")
  sanitisationFlagReason String?  @map("sanitisation_flag_reason") @db.VarChar(100)
  outputValidationPassed Boolean? @map("output_validation_passed")
  outputHardFailures     String[] @map("output_hard_failures")
  outputAutoCorrections  String[] @map("output_auto_corrections")
  modelUsed              String?  @map("model_used") @db.VarChar(100)
  serviceCategory        String?  @map("service_category") @db.VarChar(100)
  flagTriggered          Boolean  @default(false) @map("flag_triggered")
  flagReasons            String[] @map("flag_reasons")
  requiredRegeneration   Boolean  @default(false) @map("required_regeneration")

  tenant Tenant         @relation(fields: [tenantId], references: [id])
  job    GenerationJob? @relation(fields: [jobId], references: [id])

  @@index([tenantId, timestamp(sort: Desc)])
  @@index([tenantId, flagTriggered])
  @@map("generation_audit_log")
  @@schema("platform")
}

model GenerationFingerprint {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  fingerprint String   @db.VarChar(64)
  contentId   String?  @map("content_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant  Tenant       @relation(fields: [tenantId], references: [id])
  content ContentItem? @relation(fields: [contentId], references: [id])

  @@unique([tenantId, fingerprint], name: "unique_fingerprint_per_tenant")
  @@index([tenantId])
  @@map("generation_fingerprints")
  @@schema("platform")
}

model FailedJob {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  originalJobId   String    @map("original_job_id") @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  jobPayload      Json      @map("job_payload")
  errorMessage    String    @map("error_message") @db.Text
  errorStack      String?   @map("error_stack") @db.Text
  failedAtStep    String?   @map("failed_at_step") @db.VarChar(100)
  retryCount      Int       @default(0) @map("retry_count")
  isResolved      Boolean   @default(false) @map("is_resolved")
  resolvedAt      DateTime? @map("resolved_at") @db.Timestamptz
  resolvedById    String?   @map("resolved_by") @db.Uuid
  resolutionNotes String?   @map("resolution_notes") @db.Text
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz

  originalJob GenerationJob @relation(fields: [originalJobId], references: [id])
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  resolvedBy  User?         @relation("ResolvedBy", fields: [resolvedById], references: [id])

  @@index([tenantId])
  @@map("failed_jobs")
  @@schema("platform")
}

model AppointmentQuestionnaireResponse {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  appointmentId String    @map("appointment_id") @db.Uuid
  crmBookingId  String    @map("crm_booking_id") @db.VarChar(255)
  questionKey   String    @map("question_key") @db.Text
  questionLabel String?   @map("question_label") @db.Text
  answer        String?   @db.Text
  answeredAt    DateTime? @map("answered_at") @db.Timestamptz
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([crmBookingId])
  @@map("appointment_questionnaire_responses")
  @@schema("platform")
}

model CrmIntegrationConfig {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String    @unique @map("tenant_id") @db.Uuid
  crmSyncEnabled     Boolean   @default(false) @map("crm_sync_enabled")
  autoImportBookings Boolean   @default(false) @map("auto_import_bookings")
  autoMapMedia       Boolean   @default(true) @map("auto_map_media")
  webhookSecret      String?   @map("webhook_secret") @db.VarChar(255)
  lastSyncedAt       DateTime? @map("last_synced_at") @db.Timestamptz
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("crm_integration_configs")
  @@schema("platform")
}

model RefreshToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz
  ipAddress String?   @map("ip_address") @db.Inet
  userAgent String?   @map("user_agent") @db.Text
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
  @@schema("platform")
}

model Notification {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  type          String    @db.VarChar(100)
  title         String?   @db.VarChar(255)
  body          String?   @db.Text
  data          Json?
  readAt        DateTime? @map("read_at") @db.Timestamptz
  deliveredAt   DateTime? @map("delivered_at") @db.Timestamptz
  channelSms    Boolean   @default(false) @map("channel_sms")
  externalPhone String?   @map("external_phone") @db.VarChar(50)
  deliveryError String?   @map("delivery_error") @db.Text
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, readAt])
  @@index([tenantId, createdAt])
  @@map("notifications")
  @@schema("platform")
}
