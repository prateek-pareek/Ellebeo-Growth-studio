generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuidOssp(map: "uuid-ossp"), vector, pg_trgm, btree_gin]
}

// -----------------------------------------------------------------------------
// ENUMS
// -----------------------------------------------------------------------------
enum UserRole {
  technician
  admin
  super_admin

  @@map("user_role")
}

enum SubscriptionTier {
  free
  standard
  premium

  @@map("subscription_tier")
}

enum TenantStatus {
  active
  restricted
  suspended
  churned

  @@map("tenant_status")
}

enum ConsentStatus {
  granted
  pending
  declined
  withdrawn

  @@map("consent_status")
}

enum ServiceCategory {
  hair_colour
  hair_cut_style
  hair_extensions
  laser_treatments
  injectables_cosmetic
  skin_treatments
  nail_services
  makeup
  lashes_brows
  massage_body
  general

  @@map("service_category")
}

enum BusinessGoalType {
  attract_new_clients
  fill_quiet_days
  promote_high_margin_service
  build_brand_authority
  client_retention

  @@map("business_goal_type")
}

enum ContentStatus {
  draft
  approved
  scheduled
  published
  blocked
  flagged
  archived
  failed

  @@map("content_status")
}

enum JobState {
  created
  queued
  processing_image
  processing_vision
  building_prompt
  generating_text
  generating_reel
  completed
  failed
  retrying
  blocked
  dead_letter

  @@map("job_state")
}

enum PlatformType {
  instagram
  facebook
  tiktok

  @@map("platform_type")
}

enum PostFormat {
  feed
  story
  reel
  carousel

  @@map("post_format")
}

enum SocialAccountStatus {
  connected
  disconnected
  token_expired
  error

  @@map("social_account_status")
}

enum PublishStatus {
  pending
  published
  failed
  cancelled

  @@map("publish_status")
}

enum ToneRating {
  sounds_like_me
  close_but_not_quite
  doesnt_sound_like_me

  @@map("tone_rating")
}

enum BrandAesthetic {
  minimalist_clean
  moody_editorial
  bright_playful
  soft_feminine
  bold_luxury

  @@map("brand_aesthetic")
}

enum BrandTier {
  luxury
  mainstream
  accessible

  @@map("brand_tier")
}

// -----------------------------------------------------------------------------
// MODELS
// -----------------------------------------------------------------------------

model User {
  id                  String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email               String    @unique @db.VarChar(320)
  passwordHash        String    @map("password_hash") @db.VarChar(255)
  role                UserRole  @default(technician)
  emailVerified       Boolean   @default(false) @map("email_verified")
  emailVerifiedAt     DateTime? @map("email_verified_at") @db.Timestamptz
  lastLoginAt         DateTime? @map("last_login_at") @db.Timestamptz
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until") @db.Timestamptz
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt           DateTime? @map("deleted_at") @db.Timestamptz

  tenant        Tenant?
  refreshTokens RefreshToken[]
  approvedItems ContentItem[]  @relation("ApprovedBy")
  resolvedJobs  FailedJob[]    @relation("ResolvedBy")

  @@index([email])
  @@index([role])
  @@map("users")
}

model Tenant {
  id                    String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId                String           @unique @map("user_id") @db.Uuid
  businessName          String           @map("business_name") @db.VarChar(255)
  displayName           String?          @map("display_name") @db.VarChar(255)
  subscriptionTier      SubscriptionTier @default(free) @map("subscription_tier")
  subscriptionStartedAt DateTime?        @map("subscription_started_at") @db.Timestamptz
  subscriptionExpiresAt DateTime?        @map("subscription_expires_at") @db.Timestamptz
  status                TenantStatus     @default(active)
  generationRestricted  Boolean          @default(false) @map("generation_restricted")
  generationSuspended   Boolean          @default(false) @map("generation_suspended")
  abuseFlagCount        Int              @default(0) @map("abuse_flag_count")
  lastAbuseFlagAt       DateTime?        @map("last_abuse_flag_at") @db.Timestamptz
  stripeCustomerId      String?          @map("stripe_customer_id") @db.VarChar(255)
  stripeSubscriptionId  String?          @map("stripe_subscription_id") @db.VarChar(255)
  timezone              String           @default("UTC") @db.VarChar(100)
  locale                String           @default("en-AU") @db.VarChar(20)
  onboardingCompleted   Boolean          @default(false) @map("onboarding_completed")
  onboardingStep        Int              @default(1) @map("onboarding_step")
  createdAt             DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt             DateTime?        @map("deleted_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  brandHistory           BrandDNA[]
  brandPillars           BrandPillar[]
  brandGoals             BrandGoal[]
  clients                Client[]
  consentRecords         ConsentRecord[]
  appointments           Appointment[]
  imageAssets            ImageAsset[]
  goldenExamples         GoldenExample[]
  businessGoals          BusinessGoal[]
  generationJobs         GenerationJob[]
  contentItems           ContentItem[]
  socialAccounts         SocialAccount[]
  scheduledPosts         ScheduledPost[]
  campaigns              Campaign[]
  generationAuditLogs    GenerationAuditLog[]
  generationFingerprints GenerationFingerprint[]
  failedJobs             FailedJob[]

  @@index([userId])
  @@index([status])
  @@index([subscriptionTier])
  @@map("tenants")
}

model BrandDNA {
  id                       String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId                 String          @map("tenant_id") @db.Uuid
  version                  Int             @default(1)
  isCurrent                Boolean         @default(true) @map("is_current")
  businessName             String          @map("business_name") @db.VarChar(255)
  oneLiner                 String?         @map("one_liner") @db.Text
  uniqueSellingProposition String?         @map("unique_selling_proposition") @db.Text
  signatureOutcome         String?         @map("signature_outcome") @db.VarChar(500)
  primaryPersona           String?         @map("primary_persona") @db.VarChar(255)
  secondaryPersona         String?         @map("secondary_persona") @db.VarChar(255)
  clientPainPoints         String[]        @map("client_pain_points")
  primaryTone              String?         @map("primary_tone") @db.VarChar(100)
  secondaryTone            String?         @map("secondary_tone") @db.VarChar(100)
  emojiPolicy              String          @default("minimal") @map("emoji_policy") @db.VarChar(50)
  vocabularyBlacklist      String[]        @map("vocabulary_blacklist")
  vocabularyPreferred      String[]        @map("vocabulary_preferred")
  doNotSay                 String[]        @map("do_not_say")
  brandColourPrimary       String?         @map("brand_colour_primary") @db.VarChar(7)
  brandColourSecondary     String?         @map("brand_colour_secondary") @db.VarChar(7)
  brandColourAccent        String?         @map("brand_colour_accent") @db.VarChar(7)
  aestheticDirection       BrandAesthetic? @map("aesthetic_direction")
  typographyPreference     String?         @map("typography_preference") @db.VarChar(50)
  brandTier                BrandTier       @default(mainstream) @map("brand_tier")
  coreSpecialties          ServiceCategory[] @map("core_specialties")
  heroService              ServiceCategory?  @map("hero_service")
  heroServiceDescription   String?         @map("hero_service_description") @db.Text
  complexityScore          Float           @default(0.5) @map("complexity_score")
  preferredModelOverride   String?         @map("preferred_model_override") @db.VarChar(100)
  averageConfidenceScore   Float?          @map("average_confidence_score")
  totalGenerations         Int             @default(0) @map("total_generations")
  instagramHandle          String?         @map("instagram_handle") @db.VarChar(100)
  websiteUrl               String?         @map("website_url") @db.VarChar(500)
  autoPopulated            Boolean         @default(false) @map("auto_populated")
  createdAt                DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])
  pillars BrandPillar[]
  goals   BrandGoal[]

  @@unique([tenantId, isCurrent], name: "unique_current_brand_dna")
  @@index([tenantId])
  @@index([tenantId, isCurrent])
  @@map("brand_dna")
}

model BrandPillar {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  brandDnaId  String   @map("brand_dna_id") @db.Uuid
  label       String   @db.VarChar(255)
  description String?  @db.Text
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  brandDna BrandDNA @relation(fields: [brandDnaId], references: [id])

  @@index([brandDnaId])
  @@index([tenantId])
  @@map("brand_pillars")
}

model BrandGoal {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  brandDnaId   String   @map("brand_dna_id") @db.Uuid
  label        String   @db.VarChar(255)
  targetMetric String?  @map("target_metric") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  brandDna BrandDNA @relation(fields: [brandDnaId], references: [id])

  @@index([brandDnaId])
  @@index([tenantId])
  @@map("brand_goals")
}

model Client {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  firstName    String?   @map("first_name") @db.VarChar(255)
  lastName     String?   @map("last_name") @db.VarChar(255)
  email        String?   @db.VarChar(320)
  phone        String?   @db.VarChar(50)
  notes        String?   @db.Text
  visitCount   Int       @default(0) @map("visit_count")
  lastVisitAt  DateTime? @map("last_visit_at") @db.Timestamptz
  firstVisitAt DateTime? @map("first_visit_at") @db.Timestamptz
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  consentRecords ConsentRecord[]
  appointments   Appointment[]
  generationJobs GenerationJob[]

  @@index([tenantId])
  @@index([tenantId, email])
  @@index([tenantId, lastVisitAt(sort: Desc)])
  @@map("clients")
}

model ConsentRecord {
  id                     String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId               String        @map("tenant_id") @db.Uuid
  clientId               String        @map("client_id") @db.Uuid
  appointmentId          String?       @map("appointment_id") @db.Uuid
  status                 ConsentStatus @default(pending)
  allowShowFace          Boolean       @default(false) @map("allow_show_face")
  allowUseName           Boolean       @default(false) @map("allow_use_name")
  allowTagSocial         Boolean       @default(false) @map("allow_tag_social")
  allowPlatformPromotion Boolean       @default(false) @map("allow_platform_promotion")
  allowInternalUse       Boolean       @default(true) @map("allow_internal_use")
  allowMarketingContent  Boolean       @default(false) @map("allow_marketing_content")
  grantedAt              DateTime?     @map("granted_at") @db.Timestamptz
  withdrawnAt            DateTime?     @map("withdrawn_at") @db.Timestamptz
  declinedAt             DateTime?     @map("declined_at") @db.Timestamptz
  withdrawalReason       String?       @map("withdrawal_reason") @db.Text
  consentMethod          String?       @map("consent_method") @db.VarChar(100)
  isCurrent              Boolean       @default(true) @map("is_current")
  supersededById         String?       @map("superseded_by") @db.Uuid
  supersededAt           DateTime?     @map("superseded_at") @db.Timestamptz
  createdAt              DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant       Tenant          @relation(fields: [tenantId], references: [id])
  client       Client          @relation(fields: [clientId], references: [id])
  supersededBy ConsentRecord?  @relation("SupersededConsent", fields: [supersededById], references: [id])
  supersedes   ConsentRecord[] @relation("SupersededConsent")
  appointments Appointment[]

  @@index([clientId])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("consent_records")
}

model Appointment {
  id                 String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId           String          @map("tenant_id") @db.Uuid
  clientId           String          @map("client_id") @db.Uuid
  consentRecordId    String?         @map("consent_record_id") @db.Uuid
  serviceCategory    ServiceCategory @default(general) @map("service_category")
  serviceName        String          @map("service_name") @db.VarChar(500)
  serviceDescription String?         @map("service_description") @db.Text
  appointmentDate    DateTime        @map("appointment_date") @db.Date
  appointmentTime    DateTime?       @map("appointment_time") @db.Time()
  durationMinutes    Int?            @map("duration_minutes")
  notes              String?         @db.Text
  isCancelled        Boolean         @default(false) @map("is_cancelled")
  cancelledAt        DateTime?       @map("cancelled_at") @db.Timestamptz
  cancellationReason String?         @map("cancellation_reason") @db.Text
  contentGenerated   Boolean         @default(false) @map("content_generated")
  createdAt          DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt          DateTime?       @map("deleted_at") @db.Timestamptz

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  client        Client         @relation(fields: [clientId], references: [id])
  consentRecord ConsentRecord? @relation(fields: [consentRecordId], references: [id])

  imageAssets    ImageAsset[]
  generationJobs GenerationJob[]
  contentItems   ContentItem[]

  @@index([tenantId])
  @@index([clientId])
  @@index([tenantId, appointmentDate(sort: Desc)])
  @@index([consentRecordId])
  @@map("appointments")
}

model ImageAsset {
  id                   String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId             String    @map("tenant_id") @db.Uuid
  appointmentId        String    @map("appointment_id") @db.Uuid
  s3Key                String    @map("s3_key") @db.VarChar(1000)
  s3Bucket             String    @map("s3_bucket") @db.VarChar(255)
  s3ObjectHash         String    @map("s3_object_hash") @db.VarChar(64)
  originalFilename     String?   @map("original_filename") @db.VarChar(500)
  fileSizeBytes        BigInt?   @map("file_size_bytes")
  mimeType             String?   @map("mime_type") @db.VarChar(100)
  cloudinaryPublicId   String?   @map("cloudinary_public_id") @db.VarChar(500)
  urlFeed              String?   @map("url_feed") @db.VarChar(2000)
  urlStory             String?   @map("url_story") @db.VarChar(2000)
  urlThumbnail         String?   @map("url_thumbnail") @db.VarChar(2000)
  urlOriginalCdn       String?   @map("url_original_cdn") @db.VarChar(2000)
  visionAnalysisResult Json?     @map("vision_analysis_result")
  visionAnalysedAt     DateTime? @map("vision_analysed_at") @db.Timestamptz
  visionModelUsed      String?   @map("vision_model_used") @db.VarChar(100)
  uploadValidated      Boolean   @default(false) @map("upload_validated")
  cloudinaryProcessed  Boolean   @default(false) @map("cloudinary_processed")
  faceBlurApplied      Boolean   @default(false) @map("face_blur_applied")
  facesDetected        Boolean?  @map("faces_detected")
  isBeforePhoto        Boolean   @default(false) @map("is_before_photo")
  isAfterPhoto         Boolean   @default(false) @map("is_after_photo")
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt            DateTime? @map("deleted_at") @db.Timestamptz

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  appointment  Appointment   @relation(fields: [appointmentId], references: [id])
  contentItems ContentItem[]

  @@unique([s3ObjectHash], name: "idx_image_assets_s3_hash")
  @@index([appointmentId])
  @@index([tenantId])
  @@index([cloudinaryPublicId])
  @@map("image_assets")
}

model GoldenExample {
  id              String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId        String           @map("tenant_id") @db.Uuid
  caption         String           @db.Text
  platform        PlatformType
  serviceCategory ServiceCategory? @map("service_category")
  hashtags        String[]
  qualityScore    Float            @default(0.0) @map("quality_score")
  isApproved      Boolean          @default(false) @map("is_approved")
  isPending       Boolean          @default(false) @map("is_pending")
  source          String?          @db.VarChar(100)
  embedding       Unsupported("vector(1536)")?
  generatedAt     DateTime?        @map("generated_at") @db.Timestamptz
  approvedAt      DateTime?        @map("approved_at") @db.Timestamptz
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, serviceCategory])
  // Note: pgvector index creation must be done in raw SQL
  @@map("golden_examples")
}

model BusinessGoal {
  id            String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId      String           @map("tenant_id") @db.Uuid
  goalType      BusinessGoalType @map("goal_type")
  isActive      Boolean          @default(true) @map("is_active")
  targetValue   Int?             @map("target_value")
  currentValue  Int              @default(0) @map("current_value")
  targetPeriod  String?          @map("target_period") @db.VarChar(50)
  activatedAt   DateTime         @default(now()) @map("activated_at") @db.Timestamptz
  deactivatedAt DateTime?        @map("deactivated_at") @db.Timestamptz
  notes         String?          @db.Text
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, isActive], name: "one_active_goal_per_tenant")
  @@index([tenantId])
  @@map("business_goals")
}

model GenerationJob {
  id                     String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId               String         @map("tenant_id") @db.Uuid
  appointmentId          String         @map("appointment_id") @db.Uuid
  clientId               String         @map("client_id") @db.Uuid
  state                  JobState       @default(created)
  priority               Int            @default(5)
  jobPayload             Json           @map("job_payload")
  consentSnapshot        Json           @map("consent_snapshot")
  brandDnaSnapshot       Json           @map("brand_dna_snapshot")
  brandDnaVersion        Int            @map("brand_dna_version")
  outputFormats          String[]       @map("output_formats")
  platforms              PlatformType[]
  includeVoiceover       Boolean        @default(false) @map("include_voiceover")
  includeMusic           Boolean        @default(false) @map("include_music")
  contentItemId          String?        @map("content_item_id") @db.Uuid
  errorMessage           String?        @map("error_message") @db.Text
  errorCode              String?        @map("error_code") @db.VarChar(100)
  failedAtStep           String?        @map("failed_at_step") @db.VarChar(100)
  retryCount             Int            @default(0) @map("retry_count")
  modelUsedText          String?        @map("model_used_text") @db.VarChar(100)
  modelUsedVision        String?        @map("model_used_vision") @db.VarChar(100)
  inputTokens            Int?           @map("input_tokens")
  outputTokens           Int?           @map("output_tokens")
  estimatedCostUsd       Decimal?       @map("estimated_cost_usd") @db.Decimal(10, 8)
  brandVoiceConfidence   Float?         @map("brand_voice_confidence")
  requiredEscalation     Boolean        @default(false) @map("required_escalation")
  queuedAt               DateTime?      @map("queued_at") @db.Timestamptz
  processingStartedAt    DateTime?      @map("processing_started_at") @db.Timestamptz
  completedAt            DateTime?      @map("completed_at") @db.Timestamptz
  totalDurationMs        Int?           @map("total_duration_ms")
  createdAt              DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  appointment   Appointment   @relation(fields: [appointmentId], references: [id])
  client        Client        @relation(fields: [clientId], references: [id])
  
  contentItems         ContentItem[]        @relation("JobToContent")
  generationAuditLogs  GenerationAuditLog[]
  failedJobs           FailedJob[]

  @@index([tenantId])
  @@index([appointmentId])
  @@index([state, createdAt(sort: Desc)])
  @@index([contentItemId])
  @@map("generation_jobs")
}

model ContentItem {
  id                       String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId                 String         @map("tenant_id") @db.Uuid
  appointmentId            String         @map("appointment_id") @db.Uuid
  generationJobId          String?        @map("generation_job_id") @db.Uuid
  status                   ContentStatus  @default(draft)
  blockedReason            String?        @map("blocked_reason") @db.Text
  flaggedReason            String?        @map("flagged_reason") @db.Text
  isAdminFlagged           Boolean        @default(false) @map("is_admin_flagged")
  caption                  String?        @db.Text
  captionStatus            ContentStatus  @default(draft) @map("caption_status")
  hookSentence             String?        @map("hook_sentence") @db.Text
  callToAction             String?        @map("call_to_action") @db.Text
  altText                  String?        @map("alt_text") @db.Text
  hashtags                 String[]
  hashtagsStatus           ContentStatus  @default(draft) @map("hashtags_status")
  imageAssetId             String?        @map("image_asset_id") @db.Uuid
  processedImageUrlFeed    String?        @map("processed_image_url_feed") @db.VarChar(2000)
  processedImageUrlStory   String?        @map("processed_image_url_story") @db.VarChar(2000)
  imageStatus              ContentStatus  @default(draft) @map("image_status")
  reelMp4Url               String?        @map("reel_mp4_url") @db.VarChar(2000)
  reelThumbnailUrl         String?        @map("reel_thumbnail_url") @db.VarChar(2000)
  reelScript               String?        @map("reel_script") @db.Text
  reelStatus               ContentStatus  @default(draft) @map("reel_status")
  voiceoverUrl             String?        @map("voiceover_url") @db.VarChar(2000)
  musicTrackUrl            String?        @map("music_track_url") @db.VarChar(2000)
  captionInstagram         String?        @map("caption_instagram") @db.Text
  captionFacebook          String?        @map("caption_facebook") @db.Text
  captionTiktok            String?        @map("caption_tiktok") @db.Text
  brandVoiceScore          Float?         @map("brand_voice_score")
  technicianToneRating     ToneRating?    @map("technician_tone_rating")
  ratedAt                  DateTime?      @map("rated_at") @db.Timestamptz
  contentFingerprint       String?        @map("content_fingerprint") @db.VarChar(64)
  exportPackUrl            String?        @map("export_pack_url") @db.VarChar(2000)
  exportGeneratedAt        DateTime?      @map("export_generated_at") @db.Timestamptz
  reviewedAt               DateTime?      @map("reviewed_at") @db.Timestamptz
  approvedAt               DateTime?      @map("approved_at") @db.Timestamptz
  approvedById             String?        @map("approved_by") @db.Uuid
  createdAt                DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt                DateTime?      @map("deleted_at") @db.Timestamptz

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  appointment   Appointment    @relation(fields: [appointmentId], references: [id])
  generationJob GenerationJob? @relation("JobToContent", fields: [generationJobId], references: [id])
  imageAsset    ImageAsset?    @relation(fields: [imageAssetId], references: [id])
  approvedBy    User?          @relation("ApprovedBy", fields: [approvedById], references: [id])

  scheduledPosts         ScheduledPost[]
  generationFingerprints GenerationFingerprint[]

  @@unique([tenantId, contentFingerprint], name: "idx_content_fingerprint")
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([appointmentId])
  @@map("content_items")
}

model SocialAccount {
  id                String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId          String              @map("tenant_id") @db.Uuid
  platform          PlatformType
  platformAccountId String              @map("platform_account_id") @db.VarChar(500)
  accountName       String?             @map("account_name") @db.VarChar(500)
  accountHandle     String?             @map("account_handle") @db.VarChar(500)
  profilePictureUrl String?             @map("profile_picture_url") @db.VarChar(2000)
  status            SocialAccountStatus @default(connected)
  accessToken       String?             @map("access_token") @db.Text
  refreshToken      String?             @map("refresh_token") @db.Text
  tokenExpiresAt    DateTime?           @map("token_expires_at") @db.Timestamptz
  tokenRefreshedAt  DateTime?           @map("token_refreshed_at") @db.Timestamptz
  scopesGranted     String[]            @map("scopes_granted")
  lastPublishAt     DateTime?           @map("last_publish_at") @db.Timestamptz
  lastError         String?             @map("last_error") @db.Text
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  scheduledPosts ScheduledPost[]

  @@unique([tenantId, platform], name: "unique_platform_per_tenant")
  @@index([tenantId])
  @@index([tokenExpiresAt])
  @@map("social_accounts")
}

model ScheduledPost {
  id              String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId        String        @map("tenant_id") @db.Uuid
  contentItemId   String        @map("content_item_id") @db.Uuid
  socialAccountId String        @map("social_account_id") @db.Uuid
  campaignId      String?       @map("campaign_id") @db.Uuid
  platform        PlatformType
  postFormat      PostFormat    @map("post_format")
  captionOverride String?       @map("caption_override") @db.Text
  hashtagsOverride String[]     @map("hashtags_override")
  scheduledFor    DateTime      @map("scheduled_for") @db.Timestamptz
  publishStatus   PublishStatus @default(pending) @map("publish_status")
  publishedAt     DateTime?     @map("published_at") @db.Timestamptz
  platformPostId  String?       @map("platform_post_id") @db.VarChar(500)
  platformPostUrl String?       @map("platform_post_url") @db.VarChar(2000)
  failedAt        DateTime?     @map("failed_at") @db.Timestamptz
  failureReason   String?       @map("failure_reason") @db.Text
  retryCount      Int           @default(0) @map("retry_count")
  lastRetryAt     DateTime?     @map("last_retry_at") @db.Timestamptz
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime?     @map("deleted_at") @db.Timestamptz

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  contentItem   ContentItem   @relation(fields: [contentItemId], references: [id])
  socialAccount SocialAccount @relation(fields: [socialAccountId], references: [id])
  campaign      Campaign?     @relation(fields: [campaignId], references: [id])

  @@index([tenantId])
  @@index([tenantId, scheduledFor])
  @@index([contentItemId])
  @@index([campaignId])
  @@map("scheduled_posts")
}

model Campaign {
  id                  String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId            String           @map("tenant_id") @db.Uuid
  name                String           @db.VarChar(500)
  description         String?          @db.Text
  goalType            BusinessGoalType? @map("goal_type")
  startDate           DateTime?        @map("start_date") @db.Date
  endDate             DateTime?        @map("end_date") @db.Date
  totalPostsPlanned   Int              @default(0) @map("total_posts_planned")
  totalPostsApproved  Int              @default(0) @map("total_posts_approved")
  totalPostsPublished Int              @default(0) @map("total_posts_published")
  isActive            Boolean          @default(true) @map("is_active")
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt           DateTime?        @map("deleted_at") @db.Timestamptz

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  scheduledPosts ScheduledPost[]

  @@index([tenantId])
  @@map("campaigns")
}

model GenerationAuditLog {
  id                      String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId                String           @map("tenant_id") @db.Uuid
  jobId                   String?          @map("job_id") @db.Uuid
  timestamp               DateTime         @default(now()) @db.Timestamptz
  inputInstruction        String?          @map("input_instruction") @db.Text
  sanitisationPassed      Boolean          @map("sanitisation_passed")
  sanitisationFlagReason  String?          @map("sanitisation_flag_reason") @db.VarChar(100)
  outputValidationPassed  Boolean?         @map("output_validation_passed")
  outputHardFailures      String[]         @map("output_hard_failures")
  outputAutoCorrections   String[]         @map("output_auto_corrections")
  modelUsed               String?          @map("model_used") @db.VarChar(100)
  serviceCategory         ServiceCategory? @map("service_category")
  flagTriggered           Boolean          @default(false) @map("flag_triggered")
  flagReasons             String[]         @map("flag_reasons")
  requiredRegeneration    Boolean          @default(false) @map("required_regeneration")

  tenant Tenant         @relation(fields: [tenantId], references: [id])
  job    GenerationJob? @relation(fields: [jobId], references: [id])

  @@index([tenantId, timestamp(sort: Desc)])
  @@index([tenantId, flagTriggered])
  @@map("generation_audit_log")
}

model GenerationFingerprint {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  fingerprint String   @db.VarChar(64)
  contentId   String?  @map("content_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant  Tenant       @relation(fields: [tenantId], references: [id])
  content ContentItem? @relation(fields: [contentId], references: [id])

  @@unique([tenantId, fingerprint], name: "unique_fingerprint_per_tenant")
  @@index([tenantId])
  @@map("generation_fingerprints")
}

model FailedJob {
  id               String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  originalJobId    String    @map("original_job_id") @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  jobPayload       Json      @map("job_payload")
  errorMessage     String    @map("error_message") @db.Text
  errorStack       String?   @map("error_stack") @db.Text
  failedAtStep     String?   @map("failed_at_step") @db.VarChar(100)
  retryCount       Int       @default(0) @map("retry_count")
  isResolved       Boolean   @default(false) @map("is_resolved")
  resolvedAt       DateTime? @map("resolved_at") @db.Timestamptz
  resolvedById     String?   @map("resolved_by") @db.Uuid
  resolutionNotes  String?   @map("resolution_notes") @db.Text
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz

  originalJob GenerationJob @relation(fields: [originalJobId], references: [id])
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  resolvedBy  User?         @relation("ResolvedBy", fields: [resolvedById], references: [id])

  @@index([tenantId])
  @@map("failed_jobs")
}

model RefreshToken {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  tokenHash   String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz
  revokedAt   DateTime? @map("revoked_at") @db.Timestamptz
  ipAddress   String?   @map("ip_address") @db.Inet
  userAgent   String?   @map("user_agent") @db.Text
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}
