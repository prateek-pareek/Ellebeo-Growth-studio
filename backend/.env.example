# Elle.Be.O Growth Studio — Environment Variables
# Copy to .env and fill in real values. Never commit .env to version control.

# ── PostgreSQL ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/growthstudio_ai"

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""
REDIS_TLS="false"

# ── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=""

# ── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=""

# ── Firebase ────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_STORAGE_BUCKET=""

# ── Cloudinary ──────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── Shotstack ───────────────────────────────────────────────────────────────
SHOTSTACK_API_KEY=""
SHOTSTACK_ENV="stage"   # stage | production

# ── ElevenLabs ──────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=""

# ── Pixabay ─────────────────────────────────────────────────────────────────
PIXABAY_API_KEY=""

# ── Application ─────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT="3001"
FRONTEND_URL="http://localhost:3000"
ADMIN_PORTAL_URL="http://localhost:3010"
# Optional: extra CORS-allowed origins beyond FRONTEND_URL/ADMIN_PORTAL_URL, comma-separated
# ALLOWED_ORIGINS="https://staging.example.com,https://preview.example.com"

# ── OpenTelemetry ───────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4317"
OTEL_SERVICE_NAME="growthstudio-ai-layer"
